<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="mainBorderPane" xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.education.controllers.MainViewController"
            prefHeight="800.0" prefWidth="1200.0">
    <top>
        <VBox style="-fx-background-color: #2E5090; -fx-padding: 20;">
            <HBox spacing="20">
                <Label text="Education Platform" style="-fx-text-fill: white; -fx-font-size: 28; -fx-font-weight: bold;"/>
                <Label fx:id="userLabel" style="-fx-text-fill: #B0C4DE; -fx-font-size: 14;" HBox.hgrow="ALWAYS"/>
                <Button text="Logout" onAction="#handleLogout" style="-fx-padding: 5;"/>
            </HBox>
            <Label text="Supporting SDG 4: Quality Education" style="-fx-text-fill: #B0C4DE; -fx-font-size: 14;"/>
        </VBox>
    </top>
    <left>
        <VBox spacing="10" style="-fx-padding: 20; -fx-background-color: #F5F5F5;">
            <Button text="Dashboard" prefWidth="150" onAction="#handleViewCourses" style="-fx-padding: 10;"/>
            <Button text="Courses" prefWidth="150" onAction="#handleViewCourses" style="-fx-padding: 10;"/>
            <Button text="Quizzes" prefWidth="150" onAction="#handleViewQuizzes" style="-fx-padding: 10;"/>
            <Button text="Videos" prefWidth="150" onAction="#handleViewVideos" style="-fx-padding: 10;"/>
            <Button text="Discussion Forum" prefWidth="150" onAction="#handleAccessForum" style="-fx-padding: 10;"/>
        </VBox>
    </left>
    <center>
        <VBox fx:id="mainContainer" spacing="20" style="-fx-padding: 30;">
            <Label fx:id="titleLabel" style="-fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label text="Explore courses, take quizzes, watch video lessons, and engage with the learning community." 
                   style="-fx-font-size: 14; -fx-text-fill: #666;"/>
        </VBox>
    </center>
</BorderPane>
